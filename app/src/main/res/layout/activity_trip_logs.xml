<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:paddingTop="?attr/actionBarSize">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        
        <!-- Header with Refresh Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trip Logs"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>
            
            <Button
                android:id="@+id/btn_refresh_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
        </LinearLayout>
        
        <TextView
            android:id="@+id/tv_log_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 log files"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="8dp"/>
        
        <Button
            android:id="@+id/btn_clear_all_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear All Logs"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        
        <!-- Empty State -->
        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No trip logs captured yet.\n\nEnable logging in Developer Settings and start a trip to begin capturing data."
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>
        
        <!-- Log Files List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_log_files"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        
    </LinearLayout>
</ScrollView>
